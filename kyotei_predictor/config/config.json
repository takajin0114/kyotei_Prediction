{
  "data": {
    "raw_dir": "data/raw",
    "processed_dir": "data/processed",
    "output_dir": "outputs",
    "backup_dir": "data/backup",
    "max_file_size": "100MB",
    "compression": true
  },
  "api": {
    "timeout": 30,
    "retry_count": 3,
    "retry_delay": 2,
    "rate_limit": 10,
    "user_agent": "KyoteiPredictor/1.0"
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "logs/kyotei_predictor.log",
    "max_size": "10MB",
    "backup_count": 5
  },
  "prediction": {
    "model_dir": "optuna_models",
    "results_dir": "optuna_results",
    "top_predictions": 20,
    "confidence_threshold": 0.1,
    "max_combinations": 120
  },
  "batch": {
    "max_workers": 8,
    "chunk_size": 100,
    "progress_interval": 10,
    "lock_timeout": 3600
  },
  "web": {
    "host": "0.0.0.0",
    "port": 5000,
    "debug": false,
    "secret_key": "your-secret-key-here"
  }
} 